# Beny-Joe Cloud V5 environment variables example
PORT=3000

# PostgreSQL Connection String (e.g. Neon, Supabase, self-hosted)
DATABASE_URL=

# Upstash Redis Credentials (REST interface or PG proxy)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Backblaze B2 or S3 Compatible Endpoint Credentials
B2_KEY_ID=
B2_APP_KEY=
B2_ENDPOINT=
B2_BUCKET=

# Cryptographic Master Password / Key for Secret Encryption
# Must be exactly 64 hex characters (32 bytes) for AES-256-GCM / CBC
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# JWT Configuration
JWT_SECRET=your-256-bit-secret-here
JWT_EXPIRES_IN=7d
SESSION_SECRET=your-session-secret-here

# GROQ API Keys (rotation automatique)
GROQ_API_KEY_1=
GROQ_API_KEY_2=
GROQ_API_KEY_3=

# Platform Limits
MAX_UPLOAD_SIZE_MB=50
MAX_APPS_PER_USER=50
MAX_PROCESSES=15

# Render Base Domain
BASE_DOMAIN=onrender.com
