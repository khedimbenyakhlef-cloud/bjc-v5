# Beny-Joe Cloud V5 environment variables example
PORT=3000

# PostgreSQL Connection String (e.g. Neon, Supabase, self-hosted)
DATABASE_URL=

# Upstash Redis Credentials (REST interface or PG proxy)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Backblaze B2 or S3 Compatible Endpoint Credentials
B2_APPLICATION_KEY_ID=
B2_APPLICATION_KEY=
B2_ENDPOINT=
B2_BUCKET_NAME=

# Cryptographic Master Password / Key for Secret Encryption
# Must be exactly 64 hex characters (32 bytes) for AES-256-GCM / CBC
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
